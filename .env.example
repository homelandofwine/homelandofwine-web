# --- Database (Postgres) ---
# Local dev: postgresql://localhost:5432/homelandofwine
# Production: Neon pooled connection string (postgresql://user:pass@...-pooler.../db?sslmode=require)
DATABASE_URL=postgresql://localhost:5432/homelandofwine

# --- Payload ---
# Long random string; generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# --- Site ---
# Full public URL, no trailing slash. Used for canonical URLs, sitemap, emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Newsletter / email ---
# HMAC secret for unsubscribe links; generate with: openssl rand -hex 32
NEWSLETTER_SECRET=
# Resend API key. Leave empty in dev — emails are logged to console instead of sent.
RESEND_API_KEY=
# Sender shown to readers. The domain must be verified in Resend.
# This is send-only — no mailbox needs to exist at this address.
EMAIL_FROM=Homeland of Wine <news@yourdomain.com>
# Where subscriber replies land (e.g. your Gmail). Optional.
EMAIL_REPLY_TO=homelandofwinemagazine@gmail.com

# --- Media storage (production only) ---
# Vercel Blob read-write token. Leave empty in dev — files are stored on disk.
BLOB_READ_WRITE_TOKEN=
